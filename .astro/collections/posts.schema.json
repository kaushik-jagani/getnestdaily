{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "reading_time": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta_description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category",
    "date",
    "author",
    "image"
  ]
}