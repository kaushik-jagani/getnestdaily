---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Contact Us — Get in Touch with TrendBriefly"
    description="Contact the TrendBriefly team for questions, corrections, or collaboration opportunities. We aim to respond within 48 business hours. Reach out about AI, tech coverage, or partnerships."
    canonical="https://getnestdaily.xyz/pages/contact/"
    ogImage="/assets/images/og-default.jpg"
>
    <section class="page-header">
        <div class="container">
            <h1>Contact Us</h1>
            <p>Questions, corrections, or collaboration - we read every message.</p>
        </div>
    </section>

    <section class="contact-section">
        <div class="container">
            <div class="contact-page-layout">

                <!-- Contact details column -->
                <div class="contact-info-col">
                    <h2>Get in Touch</h2>
                    <p>TrendBriefly is an independent publication. The best way to reach us is by email. We do not have a support phone line.</p>

                    <div class="contact-cards">
                        <div class="contact-card">
                            <div class="contact-card-icon" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                            </div>
                            <div>
                                <h4>Email</h4>
                                <p><a href="mailto:hello@getnestdaily.xyz" class="contact-link">hello@getnestdaily.xyz</a></p>
                            </div>
                        </div>
                        <div class="contact-card">
                            <div class="contact-card-icon" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <div>
                                <h4>Response Time</h4>
                                <p>Within 48 business hours (Monday-Friday, 9 AM-5 PM IST)</p>
                            </div>
                        </div>
                    </div>

                    <h3 class="contact-table-heading">What to Include in Your Email</h3>
                    <div class="contact-table-wrap">
                        <table class="contact-table">
                            <thead>
                                <tr>
                                    <th>Inquiry Type</th>
                                    <th>What to Include</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Content correction</td>
                                    <td>Article URL and the specific section that needs correcting</td>
                                </tr>
                                <tr>
                                    <td>Editorial pitch</td>
                                    <td>Topic summary, your background, and 2-3 relevant writing samples</td>
                                </tr>
                                <tr>
                                    <td>Advertising inquiry</td>
                                    <td>Your company name, target audience, and preferred format</td>
                                </tr>
                                <tr>
                                    <td>General feedback</td>
                                    <td>Article URL (if applicable) and your question or comment</td>
                                </tr>
                                <tr>
                                    <td>Privacy / data request</td>
                                    <td>Subject: "Privacy Request" - see our <a href="/pages/privacy-policy/">Privacy Policy</a> for details</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="contact-notice">
                        <p><strong>Please note:</strong> We do not accept unsolicited link insertion requests, paid guest posts without disclosure, or press releases for verbatim publication. Such emails will not receive a response.</p>
                    </div>
                </div>

            </div>
        </div>
    </section>
</BaseLayout>


