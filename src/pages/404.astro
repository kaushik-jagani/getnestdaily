---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Page Not Found — TrendBriefly"
    description="The requested page could not be found on TrendBriefly."
    robots="noindex, follow"
>
    <div class="error-page" style="text-align: center; padding: 100px 20px; min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h1 style="font-size: 4rem; margin-bottom: 1rem;">404</h1>
        <p style="font-size: 1.2rem; margin-bottom: 2rem; color: var(--text-secondary);">The page you're looking for doesn't exist.</p>
        <nav style="display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center;">
            <a href="/" style="color: var(--accent); text-decoration: none; font-weight: 600;">Home</a>
            <a href="/pages/blog/" style="color: var(--accent); text-decoration: none; font-weight: 600;">Blog</a>
            <a href="/pages/about/" style="color: var(--accent); text-decoration: none; font-weight: 600;">About</a>
        </nav>
    </div>
</BaseLayout>

