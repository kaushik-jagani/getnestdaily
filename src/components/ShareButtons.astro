<div class="share-section">
    <h4>Share This Article</h4>
    <div class="share-buttons">
        <a href="#" class="share-btn facebook" data-share="facebook">Facebook</a>
        <a href="#" class="share-btn twitter" data-share="twitter">Twitter</a>
        <a href="#" class="share-btn linkedin" data-share="linkedin">LinkedIn</a>
        <a href="#" class="share-btn copy" data-share="copy">Copy Link</a>
    </div>
</div>

<script is:inline>
  (function() {
    var rawUrl = window.location.href;
    var url = rawUrl;
    try {
      var parsed = new URL(rawUrl);
      // Only share URLs from this site's own hostname
      url = (parsed.protocol === 'https:' || parsed.protocol === 'http:') ? parsed.href : rawUrl;
    } catch(e) {}
    var title = document.title;
    document.querySelectorAll('.share-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var type = btn.getAttribute('data-share');
        if (type === 'facebook') window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url), '_blank', 'width=600,height=400,noopener,noreferrer');
        else if (type === 'twitter') window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent('Check out: ' + title) + '&url=' + encodeURIComponent(url), '_blank', 'width=600,height=400,noopener,noreferrer');
        else if (type === 'linkedin') window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(url), '_blank', 'width=600,height=400,noopener,noreferrer');
        else if (type === 'copy') {
          navigator.clipboard.writeText(url).then(function() {
            btn.textContent = 'Copied! \u2713';
            setTimeout(function() { btn.textContent = 'Copy Link'; }, 2000);
          });
        }
      });
    });
  })();
</script>
